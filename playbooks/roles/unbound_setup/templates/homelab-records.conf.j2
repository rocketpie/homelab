server:
{% for record in unbound_setup_effective_dns_records %}
{% set fqdn = record.name if '.' ~ unbound_setup_local_tld in record.name or record.name.endswith('.' ~ unbound_setup_local_tld) else record.name ~ '.' ~ unbound_setup_local_tld %}
  local-data: "{{ fqdn }} IN A {{ record.value }}"
{% endfor %}

