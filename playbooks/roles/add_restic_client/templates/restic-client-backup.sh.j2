#!/usr/bin/env bash
set -euo pipefail

RESTIC_CLIENT_ENV_FILE={{ item.env_file | quote }}
RESTIC_CLIENT_BINARY={{ add_restic_client_binary_path | quote }}
RESTIC_CLIENT_BACKUP_PATH={{ item.backup_path_resolved | quote }}
RESTIC_CLIENT_IGNORE_FILENAME={{ add_restic_client_backup_ignore_filename | quote }}

if [[ ! -f "$RESTIC_CLIENT_ENV_FILE" ]]; then
  echo "Missing restic client env file: $RESTIC_CLIENT_ENV_FILE" >&2
  exit 1
fi

set -a
source "$RESTIC_CLIENT_ENV_FILE"
set +a

restic_ignore_files=()
while IFS= read -r restic_ignore_file; do
  restic_ignore_files+=("$restic_ignore_file")
done < <(
  find "$RESTIC_CLIENT_BACKUP_PATH" \
    -maxdepth 2 \
    -type f \
    -name "$RESTIC_CLIENT_IGNORE_FILENAME" \
    -print \
    | sort
)

echo "Repository: {{ item.repository_display }}"
echo "Backup path: $RESTIC_CLIENT_BACKUP_PATH"
if (( $(printf '%s\n' "${restic_ignore_files[@]}" | sed '/^$/d' | wc -l) > 0 )); then
  echo "Using .backupignore files: ${restic_ignore_files[*]}"
fi
{% if item.backup_pre_command_resolved | length > 0 %}
echo "Running pre-backup command"
{{ item.backup_pre_command_resolved }}
{% endif %}

restic_arguments=(
  backup
)
for restic_ignore_file in "${restic_ignore_files[@]}"; do
  restic_arguments+=(
    --iexclude-file
    "$restic_ignore_file"
  )
done
{% for backup_option in item.backup_options_resolved %}
restic_arguments+=({{ backup_option | quote }})
{% endfor %}
restic_arguments+=(
  "$RESTIC_CLIENT_BACKUP_PATH"
  "$@"
)

exec "$RESTIC_CLIENT_BINARY" "${restic_arguments[@]}"
