#!/usr/bin/env bash
set -euo pipefail

RESTIC_RESTORE_ENV_FILE={{ item.env_file | quote }}
RESTIC_RESTORE_BINARY={{ add_restic_client_binary_path | quote }}
RESTIC_RESTORE_LOG_DIR={{ add_restic_client_restore_log_dir | quote }}
RESTIC_RESTORE_SCRIPT_NAME={{ item.restore_script_name | quote }}

if [[ ! -f "$RESTIC_RESTORE_ENV_FILE" ]]; then
  echo "Missing restic restore env file: $RESTIC_RESTORE_ENV_FILE" >&2
  exit 1
fi

set -a
source "$RESTIC_RESTORE_ENV_FILE"
set +a

SNAPSHOT="latest"
RESTIC_RESTORE_FOREGROUND=0
RESTIC_RESTORE_SNAPSHOT_SET=0
RESTIC_RESTORE_EXTRA_ARGS=()

print_usage() {
  echo "Usage: $RESTIC_RESTORE_SCRIPT_NAME [--foreground] [snapshot] [-- restic-restore-args...]"
  echo
  echo "Runs a restore for $RESTIC_RESTORE_PATH."
  echo "Default mode launches the restore in the background with nohup."
  echo "Use --foreground to keep the restore attached to the current terminal."
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --foreground)
      RESTIC_RESTORE_FOREGROUND=1
      shift
      ;;
    --background)
      RESTIC_RESTORE_FOREGROUND=0
      shift
      ;;
    -h|--help)
      print_usage
      exit 0
      ;;
    --)
      shift
      RESTIC_RESTORE_EXTRA_ARGS+=("$@")
      break
      ;;
    -*)
      RESTIC_RESTORE_EXTRA_ARGS+=("$1")
      shift
      ;;
    *)
      if [[ "$RESTIC_RESTORE_SNAPSHOT_SET" == "0" ]]; then
        SNAPSHOT="$1"
        RESTIC_RESTORE_SNAPSHOT_SET=1
      else
        RESTIC_RESTORE_EXTRA_ARGS+=("$1")
      fi
      shift
      ;;
  esac
done

RESTIC_RESTORE_ARGS=(
  "$RESTIC_RESTORE_BINARY"
  restore
  "$SNAPSHOT"
  --target
  /
  --include
  "$RESTIC_RESTORE_PATH"
  "${RESTIC_RESTORE_EXTRA_ARGS[@]}"
)


echo "Repository: {{ item.repository_display }}"
echo "Restore path: $RESTIC_RESTORE_PATH"
echo "Snapshot: $SNAPSHOT"
echo "Mode: $([[ "$RESTIC_RESTORE_FOREGROUND" == "1" ]] && echo "Foreground" || echo "Background")"
echo "Command: restic restore $SNAPSHOT --target / --include $RESTIC_RESTORE_PATH"
echo
echo "This restores files back into the live target path."
echo
read -r -p "Continue? [y/N] " RESTIC_RESTORE_CONFIRM

if [[ ! "$RESTIC_RESTORE_CONFIRM" =~ ^[Yy]$ ]]; then
  echo "Restore cancelled."
  exit 1
fi


if [[ "$RESTIC_RESTORE_FOREGROUND" == "1" ]]; then
  exec "${RESTIC_RESTORE_ARGS[@]}"
  exit 0
fi

mkdir -p "$RESTIC_RESTORE_PATH"
mkdir -p "$RESTIC_RESTORE_LOG_DIR"
RESTIC_RESTORE_LOG_FILE="$RESTIC_RESTORE_LOG_DIR/${RESTIC_RESTORE_SCRIPT_NAME}-$(date +%Y%m%d-%H%M%S).log"

date >> "$RESTIC_RESTORE_LOG_FILE"
echo "Repository: {{ item.repository_display }}" >> "$RESTIC_RESTORE_LOG_FILE"
echo "Restore path: $RESTIC_RESTORE_PATH" >> "$RESTIC_RESTORE_LOG_FILE"
echo "Snapshot: $SNAPSHOT" >> "$RESTIC_RESTORE_LOG_FILE"
echo "Mode: $([[ "$RESTIC_RESTORE_FOREGROUND" == "1" ]] && echo "Foreground" || echo "Background")" >> "$RESTIC_RESTORE_LOG_FILE"
echo "Command: restic restore $SNAPSHOT --target / --include $RESTIC_RESTORE_PATH" >> "$RESTIC_RESTORE_LOG_FILE"

nohup "${RESTIC_RESTORE_ARGS[@]}" >> "$RESTIC_RESTORE_LOG_FILE" 2>&1 < /dev/null &
RESTIC_RESTORE_PID=$!
disown "$RESTIC_RESTORE_PID" 2>/dev/null || true

echo
echo "Restore started in the background."
echo "PID: $RESTIC_RESTORE_PID"
echo "Log: $RESTIC_RESTORE_LOG_FILE"
echo "Follow progress with: tail -f $RESTIC_RESTORE_LOG_FILE"
