#!/usr/bin/env bash
set -euo pipefail

homelab_admin_unit_exists() {
  local unit="$1"
  systemctl list-unit-files "$unit" --no-legend --plain 2>/dev/null | grep -Fq "$unit"
}

homelab_admin_print_unit_summary() {
  local unit="$1"
  local enabled
  local active

  if homelab_admin_unit_exists "$unit"; then
    enabled="$(systemctl is-enabled "$unit" 2>/dev/null || true)"
    active="$(systemctl is-active "$unit" 2>/dev/null || true)"
    printf '%-28s %-12s %-12s\n' "$unit" "${enabled:-unknown}" "${active:-unknown}"
  else
    printf '%-28s %-12s %-12s\n' "$unit" "missing" "missing"
  fi
}

homelab_admin_enable_and_start_units() {
  local unit

  for unit in "$@"; do
    if homelab_admin_unit_exists "$unit"; then
      echo "==> enabling and starting $unit"
      sudo systemctl enable --now "$unit"
    else
      echo "WARN: $unit is not installed on this host"
    fi
  done
}

homelab_admin_start_units() {
  local unit

  for unit in "$@"; do
    if homelab_admin_unit_exists "$unit"; then
      echo "==> starting $unit"
      sudo systemctl start "$unit"
    else
      echo "WARN: $unit is not installed on this host"
    fi
  done
}

homelab_admin_disable_and_stop_units() {
  local unit

  for unit in "$@"; do
    if homelab_admin_unit_exists "$unit"; then
      echo "==> disabling and stopping $unit"
      sudo systemctl disable --now "$unit"
    else
      echo "WARN: $unit is not installed on this host"
    fi
  done
}

homelab_admin_stop_units() {
  local unit

  for unit in "$@"; do
    if homelab_admin_unit_exists "$unit"; then
      echo "==> stopping $unit"
      sudo systemctl stop "$unit"
    else
      echo "WARN: $unit is not installed on this host"
    fi
  done
}

homelab_admin_show_deployment_history() {
  local history_file="$1"
  local history_entries_to_show="$2"
  local history_entries_output
  local -a history_entries=()

  echo
  echo "== Deployment History =="
  echo "File: $history_file"

  if [[ -f "$history_file" ]]; then
    history_entries_output="$(
      sudo awk '
        function flush_entry() {
          if (in_entry && recorded_at != "" && playbook != "") {
            if (status == "") {
              status = "unknown"
            }
            printf "%s | %s | %s\n", recorded_at, playbook, status
          }
        }
        BEGIN {
          in_entry = 0
          recorded_at = ""
          playbook = ""
          status = ""
        }
        /^(\\n)?---[[:space:]]*$/ {
          flush_entry()
          in_entry = 1
          recorded_at = ""
          playbook = ""
          status = ""
          next
        }
        /^recorded_at:[[:space:]]*/ {
          recorded_at = $0
          sub(/^recorded_at:[[:space:]]*/, "", recorded_at)
          next
        }
        /^playbook:[[:space:]]*/ {
          playbook = $0
          sub(/^playbook:[[:space:]]*/, "", playbook)
          next
        }
        /^status:[[:space:]]*/ {
          status = $0
          sub(/^status:[[:space:]]*/, "", status)
          next
        }
        END {
          flush_entry()
        }
      ' "$history_file"
    )"

    if [[ -z "$history_entries_output" ]]; then
      echo "No readable deployment entries found."
    else
      mapfile -t history_entries < <(printf '%s\n' "$history_entries_output")

      echo "First entry:"
      printf '%s\n' "${history_entries[0]}"

      if [[ -n "${history_entries[1]:-}" ]]; then
        echo
        echo "Recent entries:"
        printf '%s\n' "${history_entries[@]}" | tail -n "$history_entries_to_show"
      fi
    fi
  else
    echo "No deployment history found."
  fi

  echo
  echo "Full log: cat $history_file"
}
