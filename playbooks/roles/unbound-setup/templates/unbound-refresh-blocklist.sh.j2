#!/usr/bin/env bash
set -euo pipefail

sources_file="{{ unbound_blocklist_sources_file }}"
output_file="{{ unbound_blocklist_output_file }}"
tmp_domains="$(mktemp)"
tmp_output="$(mktemp)"
tmp_config="$(mktemp)"
trap 'rm -f "$tmp_domains" "$tmp_output" "$tmp_config"' EXIT

if [[ ! -s "$sources_file" ]]; then
  cat >"$output_file" <<'EOF'
# No blocklist sources configured
EOF
  exit 0
fi

while IFS= read -r source; do
  [[ -z "$source" ]] && continue
  [[ "$source" =~ ^# ]] && continue

  curl -fsSL "$source" |
    awk '
      function normalize(name) {
        name = tolower(name)
        sub(/^\*\./, "", name)
        sub(/\.$/, "", name)
        return name
      }

      /^[[:space:]]*#/ { next }
      NF == 0 { next }
      /^[[:space:]]*\$/ { next }
      /^[[:space:]]*;/ { next }
      {
        sub(/[[:space:]]*#.*/, "", $0)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0)
        if ($0 == "") {
          next
        }

        split($0, fields, /[[:space:]]+/)
        field_count = length(fields)
        domain = ""

        if (field_count >= 3 && toupper(fields[2]) == "CNAME" && fields[3] == ".") {
          domain = fields[1]
        }
        else if (field_count == 1) {
          domain = fields[1]
        }
        else if (field_count >= 2) {
          domain = fields[2]
        }

        domain = normalize(domain)
        if (domain == "localhost" || domain == "localhost.localdomain") {
          next
        }
        if (domain == "" || domain == ".") {
          next
        }
        print domain
      }
    ' >>"$tmp_domains"
done <"$sources_file"

sort -u "$tmp_domains" |
  awk '
    BEGIN {
      print "# Managed by Ansible via unbound-refresh-blocklist"
      print "server:"
    }
    {
      print "  local-zone: \"" $1 "\" always_nxdomain"
    }
  ' >"$tmp_output"

cat >"$tmp_config" <<EOF
include: "$tmp_output"
EOF

unbound-checkconf "$tmp_config" >/dev/null

chmod 0644 "$tmp_output"
mv "$tmp_output" "$output_file"
