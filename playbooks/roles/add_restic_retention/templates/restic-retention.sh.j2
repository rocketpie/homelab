#!/usr/bin/env bash
set -euo pipefail

failed=0

echo "Starting restic retention run"

{% if add_restic_retention_password_ready_repositories | length == 0 %}
echo "WARN: no enabled repositories have repository passwords configured"
{% endif %}
{% for repository in add_restic_retention_password_ready_repositories %}
echo
echo "==> {{ repository.key }}"

if [[ ! -d {{ repository.local_path | quote }} ]]; then
  echo "WARN: configured repository missing: {{ repository.local_path }}"
else
  if [[ ! -f {{ (repository.local_path ~ '/config') | quote }} ]]; then
    echo "WARN: repository config file missing: {{ repository.local_path }}/config"
  elif [[ ! -f {{ repository.env_file | quote }} ]]; then
    echo "WARN: repository env file missing: {{ repository.env_file }}"
  else
    set -a
    # shellcheck disable=SC1090
    source {{ repository.env_file | quote }}
    set +a

    if [[ -z "${RESTIC_PASSWORD:-}" ]]; then
      echo "ERROR: RESTIC_PASSWORD missing in {{ repository.env_file }}"
      failed=1
    else
      if ! {{ add_restic_retention_binary_path | quote }} -r {{ repository.local_path | quote }} forget {% for argument in repository.forget_args %}{{ argument | quote }} {% endfor %}; then
        echo "ERROR: retention run failed for {{ repository.key }}"
        failed=1
      fi
    fi

    unset RESTIC_PASSWORD || true
  fi
fi
{% endfor %}

exit "$failed"
